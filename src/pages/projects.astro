---
import projects from "../collections/projects.json";
import PageHeading from "../components/page-heading.astro";
import Project from "../components/project.astro";
import Layout from "../layouts/main.astro";
---

<Layout title="Mis Proyectos - Gonzalo Salas Tranolao">
  <!-- Hero Section -->
  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-900/40 via-purple-900/30 through-purple-800/20 to-pink-900/30"></div>
    <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
    
    <div class="relative z-10 text-center px-4 sm:px-6 max-w-4xl mx-auto py-16">
      <!-- Badge -->
      <div class="inline-flex items-center px-6 py-3 mb-12 text-sm font-bold text-indigo-700 bg-gradient-to-r from-indigo-100 to-purple-100 rounded-full border border-indigo-300 shadow-lg shadow-indigo-500/20 animate-pulse">
        <div class="w-3 h-3 bg-indigo-500 rounded-full mr-3 animate-ping"></div>
        <div class="w-2 h-2 bg-indigo-400 rounded-full mr-3"></div>
        <span class="tracking-wider uppercase">Portfolio Destacado</span>
      </div>
      
      <!-- Title -->
      <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black mb-8 bg-gradient-to-r from-cyan-600 via-indigo-600 to-purple-600 bg-clip-text text-transparent drop-shadow-2xl">
        <span class="inline-block hover:scale-110 transition-transform duration-300 cursor-default">Mis</span>
        <span class="inline-block hover:scale-110 transition-transform duration-300 cursor-default ml-4">Proyectos</span>
      </h1>
      
      <!-- Description -->
      <div class="space-y-6 mb-16">
        <div class="max-w-4xl mx-auto">
          <p class="text-2xl sm:text-3xl text-slate-700 leading-relaxed font-light">
            Aquí tienes algunos de los proyectos <span class="text-transparent bg-gradient-to-r from-pink-600 to-red-600 bg-clip-text font-bold">actuales</span> en los que he estado trabajando.
          </p>
        </div>
        
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 max-w-4xl mx-auto mb-8">
          <div class="glass rounded-xl p-4 sm:p-6 text-center bg-gradient-to-br from-blue-500/10 to-purple-500/10 border border-blue-500/20">
            <div class="text-3xl sm:text-4xl font-black text-transparent bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text mb-2">{projects.length}</div>
            <div class="text-sm sm:text-base text-slate-300 font-medium">Proyectos Activos</div>
          </div>
          <div class="glass rounded-xl p-4 sm:p-6 text-center bg-gradient-to-br from-green-500/10 to-emerald-500/10 border border-green-500/20">
            <div class="text-3xl sm:text-4xl font-black text-transparent bg-gradient-to-r from-green-400 to-emerald-400 bg-clip-text mb-2">100%</div>
            <div class="text-sm sm:text-base text-slate-300 font-medium">Completados</div>
          </div>
          <div class="glass rounded-xl p-4 sm:p-6 text-center bg-gradient-to-br from-orange-500/10 to-red-500/10 border border-orange-500/20">
            <div class="text-3xl sm:text-4xl font-black text-transparent bg-gradient-to-r from-orange-400 to-red-400 bg-clip-text mb-2">24/7</div>
            <div class="text-sm sm:text-base text-slate-300 font-medium">Disponible</div>
          </div>
        </div>
        
        <div class="max-w-3xl mx-auto">
          <p class="text-xl sm:text-2xl text-slate-600 leading-relaxed italic">
            Realmente disfruto crear nuevos proyectos y generar nuevas ideas.
          </p>
          <p class="text-xl sm:text-2xl text-slate-700 leading-relaxed font-semibold mt-4">
            <span class="text-transparent bg-gradient-to-r from-cyan-600 via-blue-600 to-indigo-600 bg-clip-text animate-pulse">Siempre estoy trabajando en algo nuevo</span>,
            <span class="block mt-2 text-lg sm:text-xl text-slate-500">¡así que vuelve a revisar con frecuencia!</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Filter and Sort Options -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
    <div class="flex flex-wrap gap-2">
      <button class="px-4 py-2 text-sm font-medium text-slate-300 bg-indigo-500/20 border border-indigo-500/30 rounded-full hover:bg-indigo-500/30 transition-colors">
        Todos
      </button>
      <button class="px-4 py-2 text-sm font-medium text-slate-400 bg-slate-700/30 border border-slate-600/30 rounded-full hover:bg-slate-600/30 transition-colors">
        Mobile
      </button>
      <button class="px-4 py-2 text-sm font-medium text-slate-400 bg-slate-700/30 border border-slate-600/30 rounded-full hover:bg-slate-600/30 transition-colors">
        Web
      </button>
      <button class="px-4 py-2 text-sm font-medium text-slate-400 bg-slate-700/30 border border-slate-600/30 rounded-full hover:bg-slate-600/30 transition-colors">
        Open Source
      </button>
    </div>
    
    <div class="flex items-center gap-2 text-sm text-slate-400">
      <span>Ordenar por:</span>
      <select class="bg-slate-700/50 border border-slate-600/30 rounded-lg px-3 py-1 text-slate-300 focus:outline-none focus:border-indigo-500/50">
        <option>Recientes</option>
        <option>Nombre</option>
        <option>Tipo</option>
      </select>
    </div>
  </div>

  <!-- Projects Grid -->
  <section class="relative py-16 sm:py-20 lg:py-24 px-4 sm:px-6 -mt-32">
    <!-- Background Extension -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-purple-900/20 to-slate-900/80 pointer-events-none"></div>
    <div class="relative z-10 max-w-7xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
        {projects.map((project, index) => (
          <div class="group relative">
            <!-- Card Background Effect -->
            <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/20 through-purple-500/15 to-purple-600/10 rounded-2xl opacity-0 group-hover:opacity-100 transition-all duration-500 transform group-hover:scale-105"></div>
            
            <!-- Project Card -->
            <div class="relative glass rounded-2xl border border-slate-700/50 hover:border-indigo-500/50 transition-all duration-500 hover:shadow-2xl overflow-hidden">
              <!-- Project Header -->
              <div class="relative p-6 pb-0">
                <!-- Project Number Badge -->
                <div class="absolute top-4 right-4 w-8 h-8 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full flex items-center justify-center text-white font-bold text-sm shadow-lg">
                  {index + 1}
                </div>
                
                <!-- Project Type Badge -->
                <div class="inline-block px-3 py-1 mb-4 text-xs font-bold text-indigo-300 bg-indigo-500/20 rounded-full border border-indigo-500/30">
                  {project.url.includes('android') || project.name.includes('App') ? 'Mobile' : project.url.includes('github') ? 'Open Source' : 'Web'}
                </div>
                
                <!-- Project Title -->
                <h3 class="text-xl sm:text-2xl font-black text-slate-100 mb-3 group-hover:text-transparent group-hover:bg-gradient-to-r group-hover:from-cyan-400 group-hover:via-blue-400 group-hover:to-indigo-400 group-hover:bg-clip-text transition-all duration-500 transform group-hover:scale-105">
                  {project.name}
                </h3>
                
                <!-- Project Description -->
                <p class="text-slate-300 leading-relaxed line-clamp-3 font-medium text-sm sm:text-base mb-4">
                  {project.description}
                </p>
              </div>
              
              <!-- Project Image -->
              <div class="relative px-6 pb-6">
                <div class="relative overflow-hidden rounded-xl">
                  <div class="absolute inset-0 bg-gradient-to-br from-indigo-600/30 through-purple-600/20 to-purple-700/15 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                  <img 
                    src={project.image} 
                    alt={project.name}
                    class="w-full h-32 sm:h-40 object-cover rounded-xl transition-all duration-500 group-hover:scale-110"
                    loading="lazy"
                  />
                  <!-- Overlay on Hover -->
                  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-end">
                    <div class="p-4 w-full">
                      <div class="flex items-center justify-between">
                        <span class="text-white text-sm font-bold">Ver proyecto</span>
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Project Footer -->
              <div class="px-6 pb-6 pt-0">
                <div class="flex items-center justify-between border-t border-slate-700/50 pt-4">
                  <!-- Project Link -->
                  <a
                    href={project.url}
                    target="_blank"
                    class="group/link flex items-center text-cyan-300 font-bold text-sm hover:text-transparent hover:bg-gradient-to-r hover:from-cyan-400 hover:to-blue-400 hover:bg-clip-text transition-all duration-300"
                  >
                    <span>Explorar</span>
                    <svg class="w-4 h-4 ml-2 transition-transform group-hover/link:translate-x-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </a>
                  
                  <!-- Status Indicator -->
                  <div class="flex items-center gap-2">
                    <div class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
                    <span class="text-xs text-slate-400 font-medium">Activo</span>
                  </div>
                </div>
                
                <!-- Tech Stack -->
                <div class="flex flex-wrap gap-2 mt-4">
                  {project.name.includes('Android') || project.name.includes('Kotlin') ? (
                    <>
                      <span class="px-2 py-1 text-xs font-medium text-green-300 bg-green-500/20 rounded-full border border-green-500/30">Android</span>
                      <span class="px-2 py-1 text-xs font-medium text-purple-300 bg-purple-500/20 rounded-full border border-purple-500/30">Kotlin</span>
                    </>
                  ) : project.name.includes('React') || project.name.includes('Node') ? (
                    <>
                      <span class="px-2 py-1 text-xs font-medium text-blue-300 bg-blue-500/20 rounded-full border border-blue-500/30">React</span>
                      <span class="px-2 py-1 text-xs font-medium text-green-300 bg-green-500/20 rounded-full border border-green-500/30">Node.js</span>
                    </>
                  ) : (
                    <>
                      <span class="px-2 py-1 text-xs font-medium text-cyan-300 bg-cyan-500/20 rounded-full border border-cyan-500/30">Web</span>
                      <span class="px-2 py-1 text-xs font-medium text-orange-300 bg-orange-500/20 rounded-full border border-orange-500/30">Frontend</span>
                    </>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <!-- CTA Section -->
      <div class="text-center mt-16 sm:mt-20">
        <div class="glass rounded-2xl p-8 max-w-2xl mx-auto bg-gradient-to-br from-slate-900/60 through-purple-900/40 to-indigo-900/30 border border-indigo-500/30 backdrop-blur-lg">
          <h3 class="text-3xl font-black text-slate-100 mb-6 bg-gradient-to-r from-cyan-400 to-blue-400 bg-clip-text text-transparent">
            ¿Interesado en colaborar?
          </h3>
          <p class="text-xl text-slate-300 mb-8 leading-relaxed">
            Si tienes un proyecto en mente o quieres ver más de mi trabajo, 
            <span class="text-transparent bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text font-semibold">no dudes en contactarme.</span>
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="https://github.com/Gonstrr"
              target="_blank"
              class="group relative inline-flex items-center px-8 py-4 text-slate-100 font-bold text-lg bg-gradient-to-r from-indigo-500 to-purple-500 rounded-xl hover:from-indigo-600 hover:to-purple-600 transition-all duration-300 transform hover:scale-110 hover:shadow-2xl hover:shadow-purple-500/50"
            >
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              Ver más en GitHub
            </a>
            <a
              href="/about"
              class="group relative inline-flex items-center px-8 py-4 text-slate-100 font-bold text-lg bg-slate-700/50 border border-slate-600/50 rounded-xl hover:bg-slate-600/50 transition-all duration-300 transform hover:scale-110 hover:shadow-xl hover:shadow-slate-500/30"
            >
              Conocer más sobre mí
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
