---
import Layout from "../layouts/main.astro";
import experiences from "../collections/experiences.json";
import Button from "../components/button.astro";
import Projects from "../components/home/projects.astro";
import Writings from "../components/home/writings.astro";

// Android Developer Skills - Modern Stack 2026
const skills = [
  // Core Android & Kotlin
  { name: "Jetpack Compose", level: 95, category: "android", icon: "🎨" },
  { name: "Kotlin", level: 95, category: "android", icon: "🤖" },
  { name: "Clean Architecture", level: 90, category: "android", icon: "🏗️" },
  { name: "MVVM", level: 90, category: "android", icon: "📱" },
  { name: "Coroutines", level: 85, category: "android", icon: "⚡" },
  { name: "Hilt", level: 85, category: "android", icon: "💉" },
  { name: "Room", level: 80, category: "android", icon: "🗄️" },
  { name: "Retrofit", level: 85, category: "android", icon: "🌐" },
  
  // Android Jetpack & Modern Tools
  { name: "Navigation Component", level: 85, category: "android", icon: "🧭" },
  { name: "ViewModel", level: 90, category: "android", icon: "📊" },
  { name: "LiveData", level: 85, category: "android", icon: "🔄" },
  { name: "Flow", level: 80, category: "android", icon: "〰️" },
  { name: "DataStore", level: 75, category: "android", icon: "💾" },
  { name: "WorkManager", level: 70, category: "android", icon: "⚙️" },
  
  // Testing & Quality
  { name: "JUnit", level: 80, category: "tools", icon: "🧪" },
  { name: "Espresso", level: 75, category: "tools", icon: "☕" },
  { name: "MockK", level: 75, category: "tools", icon: "🎭" },
  { name: "Turbine", level: 70, category: "tools", icon: "🌀" },
  
  // Web & FullStack
  { name: "JavaScript", level: 85, category: "web", icon: "⚡" },
  { name: "TypeScript", level: 80, category: "web", icon: "📘" },
  { name: "React", level: 75, category: "web", icon: "⚛️" },
  { name: "Astro", level: 70, category: "web", icon: "�" },
  { name: "Tailwind CSS", level: 85, category: "design", icon: "🎨" },
  { name: "SQL Server", level: 75, category: "backend", icon: "📊" }
];

const categories = [
  { name: "Android Core", skills: skills.filter(s => s.category === "android") },
  { name: "Testing & Tools", skills: skills.filter(s => s.category === "tools") },
  { name: "Web Development", skills: skills.filter(s => s.category === "web") },
  { name: "Backend & Design", skills: skills.filter(s => s.category === "backend" || s.category === "design") }
];
---

<Layout title="Acerca de Mi - Gonzalo Salas Tranolao">
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-purple-900/20 via-blue-900/20 to-pink-900/20"></div>
    <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
    
    <div class="relative z-10 text-center px-4 sm:px-6 max-w-4xl mx-auto">
      <!-- Status Badge -->
      <div class="inline-flex items-center px-6 py-3 mb-12 text-sm font-bold text-green-700 bg-gradient-to-r from-green-100 to-emerald-100 rounded-full border border-green-300 shadow-lg shadow-green-500/20 animate-pulse">
        <div class="w-3 h-3 bg-green-500 rounded-full mr-3 animate-ping"></div>
        <div class="w-2 h-2 bg-green-400 rounded-full mr-3"></div>
        <span class="tracking-wider uppercase">Disponible para proyectos</span>
      </div>
      
      <!-- Title -->
      <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black mb-8 bg-gradient-to-r from-cyan-600 via-indigo-600 to-purple-600 bg-clip-text text-transparent drop-shadow-2xl animate-gradient bg-gradient-to-r from-cyan-600 via-indigo-600 to-purple-600 via-pink-600 bg-clip-text text-transparent bg-[length:200%_100%] animate-shimmer">
        <span class="inline-block">Gonzalo Salas</span>
        <span class="inline-block block mt-2">Tranolao</span>
      </h1>
      
      <!-- Subtitle -->
      <h2 class="text-2xl sm:text-3xl md:text-4xl mb-12 text-slate-700 font-light tracking-widest">
        <span class="text-transparent bg-gradient-to-r from-blue-600 to-cyan-600 bg-clip-text font-semibold">Senior</span>
        <span class="mx-2">·</span>
        <span class="text-transparent bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text font-semibold">FullStack</span>
        <span class="mx-2">·</span>
        <span class="text-transparent bg-gradient-to-r from-indigo-600 to-blue-600 bg-clip-text font-semibold">Developer</span>
      </h2>
      
      <!-- Description -->
      <div class="glass rounded-2xl p-8 sm:p-10 mb-16 max-w-3xl mx-auto bg-gradient-to-br from-slate-100/80 to-purple-100/60 border border-indigo-300/50 backdrop-blur-lg">
        <p class="text-slate-800 leading-relaxed text-xl font-medium mb-6">
          Arquitecto de experiencias digitales innovadoras con especialización en 
          <span class="text-transparent bg-gradient-to-r from-cyan-600 to-blue-600 bg-clip-text font-bold text-2xl">Android nativo</span> y 
          <span class="text-transparent bg-gradient-to-r from-violet-600 to-purple-600 bg-clip-text font-bold text-2xl">desarrollo web moderno</span>.
        </p>
        <p class="text-slate-600 italic text-lg leading-relaxed">
          Transformo ideas complejas en soluciones elegantes y escalables.
        </p>
      </div>
      
      <!-- Profile Image -->
      <div class="relative inline-block mb-12">
        <div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-pink-600 rounded-full blur-xl opacity-50 animate-pulse"></div>
        <img 
          src="/assets/images/gatito.jpg" 
          alt="Gonzalo Salas" 
          class="relative w-40 h-40 sm:w-48 sm:h-48 md:w-56 md:h-56 rounded-full object-cover border-4 border-white/20 shadow-2xl"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
        />
        <div class="relative w-40 h-40 sm:w-48 sm:h-48 md:w-56 md:h-56 rounded-full bg-gradient-to-r from-purple-600 to-pink-600 flex items-center justify-center text-white text-4xl font-bold" style="display: none;">
          GS
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section class="relative py-16 sm:py-20 lg:py-24 px-4 sm:px-6 -mt-32">
    <!-- Background Extension -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-purple-900/20 to-slate-900/80 pointer-events-none"></div>
    <div class="relative z-10 max-w-6xl mx-auto">
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-center mb-16 text-slate-100">
        <span class="text-transparent bg-gradient-to-r from-cyan-400 via-blue-400 to-indigo-400 bg-clip-text font-black">Habilidades</span>
        <span class="block text-3xl sm:text-4xl md:text-5xl mt-2 text-slate-300 font-light">Técnicas</span>
      </h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
        {categories.map((category) => (
          <div class="glass rounded-xl p-6 hover:scale-105 transition-transform duration-300 bg-black/30 border border-white/10">
            <h3 class="text-xl font-bold mb-6 text-center text-slate-100 text-lg tracking-wide">
              <span class="text-transparent bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text font-semibold">{category.name}</span>
            </h3>
            <div class="space-y-3">
              {category.skills.map((skill) => (
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <span class="text-lg">{skill.icon}</span>
                    <span class="text-lg text-slate-200 font-medium">{skill.name}</span>
                  </div>
                  <span class="text-sm text-slate-300 font-bold">{skill.level}%</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Experience Timeline -->
  <section class="relative py-16 sm:py-20 lg:py-24 px-4 sm:px-6 -mt-16">
    <!-- Background Extension -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-indigo-900/15 to-slate-900/90 pointer-events-none"></div>
    <div class="relative z-10 max-w-6xl mx-auto">
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-center mb-16 text-slate-100">
        <span class="text-transparent bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text font-black">Experiencia</span>
        <span class="block text-3xl sm:text-4xl md:text-5xl mt-2 text-slate-300 font-light">Profesional</span>
      </h2>
      
      <!-- Mobile: Vertical Timeline -->
      <div class="block lg:hidden space-y-8">
        {experiences.map((experience, index) => (
          <div class="relative">
            <div class="absolute left-4 top-8 bottom-0 w-0.5 bg-gradient-to-b from-purple-600 to-transparent"></div>
            <div class="absolute left-2.5 top-4 w-3 h-3 bg-white rounded-full border-2 border-purple-600 z-10">
              <div class="absolute inset-0 bg-purple-600 rounded-full animate-ping"></div>
            </div>
            <div class="ml-8">
              <div class="glass rounded-xl p-6 hover:scale-105 transition-transform duration-300 bg-black/30 border border-white/10">
                <div class="flex items-center mb-4">
                  <img 
                    src={experience.logo} 
                    alt={experience.company}
                    class="w-12 h-12 rounded-full object-cover border-2 border-white/20 mr-4"
                  />
                  <div>
                    <div class="text-sm text-purple-300 font-medium mb-1">
                      {experience.dates}
                    </div>
                    <h3 class="text-xl font-bold text-slate-100 mb-2">
                      <span class="text-transparent bg-gradient-to-r from-cyan-400 to-blue-400 bg-clip-text font-semibold">{experience.role}</span>
                    </h3>
                    <h4 class="text-sm text-cyan-300 font-medium">
                      {experience.company}
                    </h4>
                  </div>
                </div>
                <p class="text-gray-200 leading-relaxed text-sm">
                  {experience.description}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <!-- Desktop: Horizontal Timeline -->
      <div class="hidden lg:block">
        <div class="relative overflow-x-auto pb-8">
          <div class="absolute top-1/2 left-0 right-0 h-0.5 bg-gradient-to-r from-purple-600 via-pink-600 to-blue-600 rounded-full transform -translate-y-1/2"></div>
          <div class="flex gap-8 min-w-max px-4">
            {experiences.map((experience, index) => {
              const isTop = index % 2 === 0;
              return (
                <div class="relative flex-shrink-0 w-80">
                  <div class={`relative ${isTop ? 'mb-8' : 'mt-8'}`}>
                    <div class="glass rounded-xl p-6 hover:scale-105 transition-transform duration-300 bg-black/30 border border-white/10">
                      <div class="flex items-center justify-center mb-4">
                        <img 
                          src={experience.logo} 
                          alt={experience.company}
                          class="w-16 h-16 rounded-full object-cover border-2 border-white/20"
                        />
                      </div>
                      <div class="text-center">
                        <div class="text-sm text-purple-300 font-medium mb-2">
                          {experience.dates}
                        </div>
                        <h3 class="text-xl font-bold text-slate-100 mb-3">
                          <span class="text-transparent bg-gradient-to-r from-cyan-400 to-blue-400 bg-clip-text font-semibold">{experience.role}</span>
                        </h3>
                        <h4 class="text-base text-cyan-300 font-medium mb-4">
                          {experience.company}
                        </h4>
                        <p class="text-gray-200 leading-relaxed text-sm">
                          {experience.description}
                        </p>
                      </div>
                    </div>
                  </div>
                  <div class={`absolute ${isTop ? 'bottom-0' : 'top-0'} left-1/2 transform -translate-x-1/2 w-4 h-4 bg-white rounded-full border-2 border-purple-600 z-10`}>
                    <div class="absolute inset-0 bg-purple-600 rounded-full animate-ping"></div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects & Writing Sections -->
  <section class="relative py-16 sm:py-20 lg:py-24 px-4 sm:px-6 -mt-16">
    <!-- Background Extension -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-purple-900/15 to-slate-900/90 pointer-events-none"></div>
    <div class="relative z-10 max-w-6xl mx-auto">
      <Projects />
    </div>
  </section>
  
  <section class="relative py-16 sm:py-20 lg:py-24 px-4 sm:px-6 -mt-16">
    <!-- Background Extension -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-indigo-900/15 to-slate-900/90 pointer-events-none"></div>
    <div class="relative z-10 max-w-6xl mx-auto">
      <Writings />
    </div>
  </section>

  <!-- Contact Section -->
  <section class="relative py-16 sm:py-20 lg:py-24 px-4 sm:px-6 -mt-16">
    <!-- Background Extension -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-purple-900/20 to-slate-900/95 pointer-events-none"></div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-black mb-12 text-slate-100">
        <span class="text-transparent bg-gradient-to-r from-cyan-400 via-blue-400 to-indigo-400 bg-clip-text">Conectemos</span>
      </h2>
      
      <p class="text-2xl text-slate-200 mb-16 max-w-3xl mx-auto leading-relaxed font-light">
        ¿Listo para crear algo increíble juntos? 
        <span class="text-transparent bg-gradient-to-r from-cyan-400 to-blue-400 bg-clip-text font-bold">Estoy disponible</span> para colaborar 
        en proyectos desafiantes y transformar ideas en realidad.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
        <a
          href="https://www.linkedin.com/in/gonzalo-andres-salas-tranolao/"
          target="_blank"
          class="group relative inline-flex items-center px-8 py-4 text-blue-300 font-bold text-lg bg-blue-500/20 rounded-xl border border-blue-500/30 backdrop-blur-sm hover:scale-110 transition-all duration-300 transform hover:shadow-2xl hover:shadow-blue-500/50"
        >
          <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
          <span>LinkedIn</span>
        </a>
        
        <a
          href="https://github.com/Gonstrr"
          target="_blank"
          class="group relative inline-flex items-center px-8 py-4 text-gray-300 font-bold text-lg bg-gray-500/20 rounded-xl border border-gray-500/30 backdrop-blur-sm hover:scale-110 transition-all duration-300 transform hover:shadow-2xl hover:shadow-gray-500/50"
        >
          <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span>GitHub</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
