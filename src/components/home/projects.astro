---
import projects from "../../collections/projects.json";
import Button from "../button.astro";
import Project from "../project.astro";
---

<section class="max-w-6xl mx-auto px-7 lg:px-0 py-16 lg:py-24">
  <div class="text-center mb-16">
    <h2
      class="text-3xl font-black leading-10 tracking-tight bg-gradient-to-r from-cyan-600 via-indigo-600 to-purple-600 bg-clip-text text-transparent drop-shadow-2xl 
             sm:text-4xl sm:leading-10 md:text-5xl md:leading-14 mb-4"
    >
      Mis Proyectos Destacados
    </h2>
    
    <!-- Descripción organizada en glass card -->
    <div class="glass rounded-2xl p-6 max-w-3xl mx-auto mt-8 bg-gradient-to-br from-slate-900/80 to-purple-900/60 border border-purple-500/30 backdrop-blur-lg">
      <p class="text-xl text-white leading-relaxed font-medium">
        Aquí tienes algunos de mis proyectos recientes. Siempre estoy trabajando en algo nuevo, 
        ¡así que vuelve a revisar con frecuencia!
      </p>
    </div>
  </div>
  <div
    class="grid items-stretch w-full grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8"
  >
    {
      projects.map((project) => {
        return (
          <Project
            name={project.name}
            description={project.description}
            image={project.image}
            url={project.url}
          />
        )
      })
    }
  </div>

  <div class="flex items-center justify-center w-full py-8 lg:py-12">
    <Button text="Ver todos mis proyectos" link="/projects" />
  </div>
</section>
