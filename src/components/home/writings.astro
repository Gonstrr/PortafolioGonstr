---
import { getCollection } from "astro:content";
import Button from "../button.astro";

const allPosts = await getCollection("post");
const recentPosts = allPosts.slice(0, 3);
---

<section class="max-w-6xl mx-auto px-7 lg:px-0 py-16 lg:py-24">
  <div class="text-center mb-16">
    <h2
      class="text-3xl font-black leading-10 tracking-tight bg-gradient-to-r from-cyan-600 via-indigo-600 to-purple-600 bg-clip-text text-transparent drop-shadow-2xl 
             sm:text-4xl sm:leading-10 md:text-5xl md:leading-14 mb-4"
    >
      Mis Escritos
    </h2>
    
    <!-- Descripción organizada en glass card -->
    <div class="glass rounded-2xl p-6 max-w-3xl mx-auto mt-8 bg-gradient-to-br from-slate-900/80 to-purple-900/60 border border-purple-500/30 backdrop-blur-lg">
      <p class="text-xl text-white leading-relaxed font-medium">
        Reflexiones sobre tecnología y desarrollo. Total de posts: <span class="text-transparent bg-gradient-to-r from-cyan-400 to-blue-400 bg-clip-text font-bold">{allPosts.length}</span>
      </p>
    </div>
  </div>

  <div class="space-y-8">
    {recentPosts.map((post) => (
      <div class="glass p-6 border border-purple-500/30 rounded-xl hover:shadow-lg transition-all duration-300 group bg-gradient-to-br from-slate-900/60 to-purple-900/40 backdrop-blur-lg">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
          <div class="flex-1">
            <h3 class="text-xl font-black text-white mb-2 group-hover:text-transparent group-hover:bg-gradient-to-r group-hover:from-cyan-400 group-hover:to-blue-400 group-hover:bg-clip-text transition-all duration-300">
              {post.data.title}
            </h3>
            <div class="flex items-center gap-4 text-sm text-slate-300 mb-3">
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                {post.data.dateFormatted}
              </span>
              {post.data.readTime && (
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  {post.data.readTime}
                </span>
              )}
            </div>
            <p class="text-slate-200 mb-4 line-clamp-2">
              {post.data.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {post.data.category && (
                <span class="px-3 py-1 bg-blue-500/30 text-blue-300 rounded-full text-sm font-medium border border-blue-400/50">
                  {post.data.category}
                </span>
              )}
              {post.data.difficulty && (
                <span class="px-3 py-1 bg-purple-500/30 text-purple-300 rounded-full text-sm font-medium border border-purple-400/50">
                  {post.data.difficulty}
                </span>
              )}
              {post.data.tags?.slice(0, 3).map((tag) => (
                <span class="px-3 py-1 bg-slate-500/30 text-slate-300 rounded-full text-sm border border-slate-400/50">
                  {tag}
                </span>
              ))}
            </div>
          </div>
          <div class="flex items-center">
            <a href={`/post/${post.id}`} class="inline-flex items-center px-4 py-2 text-cyan-300 font-medium hover:text-transparent hover:bg-gradient-to-r hover:from-cyan-400 hover:to-blue-400 hover:bg-clip-text transition-all duration-300">
              Leer más
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="flex items-center justify-center w-full pt-12">
    <Button text="Ver todos mis escritos" link="/posts" />
  </div>
</section>